{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@yofteam/shared-types": ["libs/shared-types/src/index.ts"],
      "@yofteam/ui": ["libs/ui/src/index.ts"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "exclude": ["node_modules", "tmp"]
}
